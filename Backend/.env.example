# ============================================================================
# Sentinel Health - Backend Environment Configuration
# ============================================================================

# Application Settings
APP_NAME=Sentinel Health API
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=True
API_PREFIX=/api/v1

# Server Configuration
HOST=0.0.0.0
PORT=8000

# CORS Settings (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ============================================================================
# PostgreSQL Database Configuration
# ============================================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=sentinel_health
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password_here

# Connection Pool Settings
POSTGRES_POOL_SIZE=5
POSTGRES_MAX_OVERFLOW=10
POSTGRES_POOL_TIMEOUT=30
POSTGRES_POOL_RECYCLE=3600

# Full connection URL (auto-generated if not provided)
# DATABASE_URL=postgresql://postgres:password@localhost:5432/sentinel_health

# ============================================================================
# MongoDB Database Configuration
# ============================================================================
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_DB=sentinel_health
MONGODB_USER=
MONGODB_PASSWORD=

# Full connection URL (auto-generated if not provided)
# MONGODB_URL=mongodb://localhost:27017/sentinel_health

# MongoDB Connection Settings
MONGODB_MAX_POOL_SIZE=10
MONGODB_MIN_POOL_SIZE=1

# ============================================================================
# Redis Configuration (Caching & Rate Limiting)
# ============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379/0

# Cache TTL (seconds)
CACHE_TTL=3600

# ============================================================================
# Authentication & Security
# ============================================================================
SECRET_KEY=your-secret-key-change-this-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Password Hashing
BCRYPT_ROUNDS=12

# ============================================================================
# External APIs
# ============================================================================

# Twitter API (twitterapi.io)
TWITTER_API_KEY=
TWITTER_API_URL=https://api.twitterapi.io/v1

# Reddit API
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=SentinelHealth/1.0

# ============================================================================
# AI/LLM Configuration
# ============================================================================

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=2000

# LangSmith (Tracing & Monitoring)
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=sentinel-health
LANGSMITH_TRACING=true

# ============================================================================
# Communication Services
# ============================================================================

# Twilio (WhatsApp)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# SendGrid (Email)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=alerts@sentinelhealth.com

# ============================================================================
# Logging & Monitoring
# ============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# Sentry (Error Tracking - Optional)
SENTRY_DSN=

# ============================================================================
# Data Retention & Cleanup
# ============================================================================
LOW_VALUE_DATA_TTL_DAYS=30
HIGH_VALUE_DATA_TTL_DAYS=0
AGENT_TRACE_TTL_DAYS=90

# ============================================================================
# Rate Limiting
# ============================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60

# ============================================================================
# Feature Flags
# ============================================================================
ENABLE_SWAGGER_UI=true
ENABLE_REDOC=true
ENABLE_METRICS=true
